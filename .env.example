# VOKUM — variables d'environnement (formulaire contact)
# Copier vers .env.local pour le dev local (vercel dev), et configurer
# les mêmes variables dans Vercel : Settings → Environment Variables.

# Clé API Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Destinataire des leads
CONTACT_TO=hello@vokum.agency

# Expéditeur (domaine vérifié chez Resend ; onboarding@resend.dev marche sans domaine pour tester)
CONTACT_FROM="Vokum <onboarding@resend.dev>"
